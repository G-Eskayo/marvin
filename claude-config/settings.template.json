{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "{{VENV_PYTHON}} {{SKILLS_DIR}}/self-improve/scripts/rebuild-manifest.py"
          },
          {
            "type": "command",
            "command": "{{VENV_PYTHON}} {{SKILLS_DIR}}/handoff/scripts/emit-resume-prompt.py"
          },
          {
            "type": "command",
            "command": "{{VENV_PYTHON}} {{SKILLS_DIR}}/qa-agent/scripts/qa_session_capture.py"
          },
          {
            "type": "command",
            "command": "{{VENV_PYTHON}} {{SKILLS_DIR}}/improve/scripts/improvement_sweep.py"
          },
          {
            "type": "command",
            "command": "{{VENV_PYTHON}} {{SKILLS_DIR}}/self-improve/scripts/background_review.py"
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "{{VENV_PYTHON}} {{AGENTS_DIR}}/brain-map/scripts/skill_activity.py"
          }
        ]
      }
    ]
  }
}
